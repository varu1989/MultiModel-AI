# JaipurEyeVision Studio - Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection (Railway provides this automatically if you add MongoDB service)
MONGO_URL="mongodb://localhost:27017"
DB_NAME="jaipureyevision"

# CORS - Frontend URL (update after Vercel deployment)
CORS_ORIGINS="http://localhost:3000,https://your-app.vercel.app"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_ALGORITHM="HS256"
JWT_EXPIRY_HOURS="24"

# Emergent LLM Key (for OpenAI, Gemini, Claude integrations)
# Get this from Emergent Platform: Profile -> Universal Key
EMERGENT_LLM_KEY="sk-emergent-your-key-here"

# Razorpay Configuration
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_key_secret"
